# =====================================================
# MAIL APP - CONFIGURACIÓN DE EJEMPLO
# =====================================================
# ⚠️ COPIA este archivo como .env y completa los valores
# ⚠️ NUNCA commitees .env a Git
# =====================================================

# -----------------------------------------------------
# GOOGLE OAUTH (Requerido)
# -----------------------------------------------------
# Obtenlas de: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu-google-client-id-aqui
GOOGLE_CLIENT_SECRET=tu-google-client-secret-aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# -----------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug

# -----------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------
# Genera uno único: openssl rand -hex 32
APP_SECRET=genera-un-secret-unico-aqui

# -----------------------------------------------------
# RENDIMIENTO
# -----------------------------------------------------
CACHE_MAX_SIZE=500
CACHE_DEFAULT_TTL=600000
ENABLE_CACHE_COMPRESSION=true
ENABLE_CACHE_PERSISTENCE=true

# -----------------------------------------------------
# BACKUP
# -----------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000

# -----------------------------------------------------
# API
# -----------------------------------------------------
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3
MAX_RESULTS=10

# -----------------------------------------------------
# LÍMITES DE SEGURIDAD
# -----------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000
SESSION_TIMEOUT=28800000
